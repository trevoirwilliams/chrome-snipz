{
  "manifest_version": 3,
  "name": "Chrome Snipz",
  "description": "Store, search, capture, and copy short reusable text snippets for faster writing across the web.",
  "version": "0.2.0",
  "minimum_chrome_version": "114",
  "action": {
    "default_title": "Open Chrome Snipz"
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "permissions": [
    "storage",
    "clipboardWrite",
    "sidePanel"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content/copy-capture.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
